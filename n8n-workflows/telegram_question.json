        "jsCode": "function getJson(url, timeoutMs) {\n  const dns = require('dns');\n  try { dns.setDefaultResultOrder('ipv4first'); } catch (error) {}\n  const https = require('https');\n  return new Promise((resolve, reject) => {\n    const req = https.get(url, res => {\n      let body = '';\n      res.on('data', chunk => body += chunk);\n      res.on('end', () => {\n        try {\n          const data = JSON.parse(body || '{}');\n          if (res.statusCode < 200 || res.statusCode >= 300 || !data.ok) {\n            reject(new Error(data.description || ('Telegram HTTP ' + res.statusCode)));\n          } else {\n            resolve(data);\n          }\n        } catch (error) {\n          reject(error);\n        }\n      });\n    });\n    req.setTimeout(timeoutMs, () => {\n      req.destroy(new Error('Telegram request timeout'));\n    });\n    req.on('error', reject);\n  });\n}\n\nconst adminId = String($env.ADMIN_TELEGRAM_IDS || '').split(',').map(v => v.trim()).filter(Boolean)[0];\nif (!adminId || !$env.TELEGRAM_ADMIN_BOT_TOKEN) return [{ json: { notification_ok: false, reason: 'admin target is not configured' } }];\nconst ticket = $('Normalize Confirmed Ticket').item.json;\nconst user = $('Route Telegram Update').item.json;\nconst text = 'Новый тикет #' + ticket.id + '\\nПользователь: ' + (user.username ? '@' + user.username : user.user_id) + '\\nВопрос: ' + ticket.question + '\\n\\nОтветить: /reply ' + ticket.id + ' текст ответа';\nconst url = 'https://api.telegram.org/bot' + $env.TELEGRAM_ADMIN_BOT_TOKEN + '/sendMessage?chat_id=' + adminId + '&text=' + encodeURIComponent(text);\ntry {\n  const data = await getJson(url, 5000);\n  return [{ json: { notification_ok: true, message_id: data.result?.message_id } }];\n} catch (error) {\n  return [{ json: { notification_ok: false, error: error.message } }];\n}\n"
