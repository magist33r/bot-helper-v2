      "parameters": {
        "jsCode": "const inputItems = $input.all();\nlet matches = [];\nif (inputItems.length === 1 && Array.isArray(inputItems[0].json)) matches = inputItems[0].json;\nelse matches = inputItems.map(item => item.json).filter(item => item && item.id !== undefined && item.content);\nreturn [{ json: { length: matches.length, matches, top_similarity: matches[0]?.similarity ?? null, context: matches.map((m, index) => `[chunk ${index + 1}, similarity=${Number(m.similarity || 0).toFixed(4)}]\\n${m.content}`).join('\\n\\n---\\n\\n') } }];"
      },
