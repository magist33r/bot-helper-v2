    {
      "parameters": {
        "jsCode": "const root = $input.first().json;\nconst update = root.body && typeof root.body === 'object' ? root.body : root;\nconst cb = update.callback_query;\nconst msg = cb?.message || update.message || {};\nconst from = cb?.from || update.message?.from || {};\nconst chat = msg.chat || {};\nconst data = String(cb?.data || '');\nlet callbackAction = '';\nlet pendingLogId = null;\nif (data.startsWith('support_yes:')) { callbackAction = 'yes'; pendingLogId = Number(data.split(':')[1]); }\nif (data.startsWith('support_no:')) { callbackAction = 'no'; pendingLogId = Number(data.split(':')[1]); }\nconst question = String(update.message?.text || '').trim();\nreturn [{ json: { update_type: cb ? 'callback_query' : 'message', is_callback: Boolean(cb), callback_action: callbackAction, pending_log_id: pendingLogId, chat_id: chat.id || 0, message_id: msg.message_id || 0, user_id: from.id || 0, username: from.username || '', question, has_text: Boolean(question), is_start: /^\\/start(?:\\s|$)/i.test(question) } }];"
      },
