        "jsCode": "const rows = $input.all().flatMap(i => Array.isArray(i.json) ? i.json : [i.json]).filter(Boolean);\nconst s = rows.find(r => r.open_tickets !== undefined) || rows[0] || {};\nconst text = ['Статистика саппорт-бота:', `Открытых тикетов: ${s.open_tickets ?? 0}`, `Закрытых тикетов: ${s.closed_tickets ?? 0}`, `Answered тикетов: ${s.answered_tickets ?? 0}`, `Всего вопросов: ${s.total_questions ?? 0}`, `% отвеченных: ${s.answered_percent ?? 0}%`, `Средняя similarity: ${s.avg_similarity ?? 'n/a'}`].join('\\n');\nreturn [{ json: { method: 'sendMessage', chat_id: $('Prepare Admin Command').item.json.chat_id, text } }];"
