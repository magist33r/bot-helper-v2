    {
      "parameters": {
        "jsCode": "function postJson(host, path, payload, timeoutMs) {\n  const dns = require('dns');\n  try { dns.setDefaultResultOrder('ipv4first'); } catch (error) {}\n  const https = require('https');\n  const body = JSON.stringify(payload);\n  return new Promise((resolve, reject) => {\n    const req = https.request({\n      hostname: host,\n      path,\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'Content-Length': Buffer.byteLength(body)\n      }\n    }, res => {\n      let data = '';\n      res.on('data', c => data += c);\n      res.on('end', () => {\n        try {\n          const parsed = JSON.parse(data || '{}');\n          if (res.statusCode < 200 || res.statusCode >= 300 || !parsed.ok) {\n            reject(new Error(parsed.description || ('Telegram HTTP ' + res.statusCode)));\n          } else {\n            resolve(parsed);\n          }\n        } catch (e) {\n          reject(e);\n        }\n      });\n    });\n    req.setTimeout(timeoutMs, () => req.destroy(new Error('Telegram request timeout')));\n    req.on('error', reject);\n    req.write(body);\n    req.end();\n  });\n}\n\nconst ticket = $('Normalize Reply Ticket').item.json;\nconst answer = $('Prepare Admin Command').item.json.reply_text;\nconst ticketId = $('Prepare Admin Command').item.json.reply_ticket_id;\nconst text = '💬 Ответ от поддержки на твой тикет #' + ticketId + ':\\n\\n' + answer + '\\n\\nЕсли остались вопросы — напиши, я постараюсь помочь.';\nconst safeText = text.length > 4090 ? text.slice(0, 4090) + '...' : text;\nconst data = await postJson('api.telegram.org', '/bot' + $env.TELEGRAM_BOT_TOKEN + '/sendMessage', { chat_id: ticket.telegram_user_id, text: safeText }, 15000);\nreturn [{ json: { telegram_ok: true, message_id: data.result?.message_id } }];"
      },
