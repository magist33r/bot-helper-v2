      "parameters": {
        "jsCode": "const tickets = $input.all().flatMap(i => Array.isArray(i.json) ? i.json : [i.json]).filter(t => t && t.id !== undefined);\nlet text = 'Открытых тикетов нет.';\nif (tickets.length) {\n  text = 'Открытые тикеты:\\n' + tickets.map(t => {\n    const username = t.username ? '@' + t.username : String(t.telegram_user_id);\n    const question = String(t.question || '').slice(0, 160);\n    return `#${t.id} ${username}: ${question}\\nОтветить: /reply ${t.id} текст ответа`;\n  }).join('\\n\\n');\n}\nreturn [{ json: { method: 'sendMessage', chat_id: $('Prepare Admin Command').item.json.chat_id, text } }];"
