        "jsCode": "const rows = $input.all().flatMap(i => Array.isArray(i.json) ? i.json : [i.json]).filter(Boolean);\nconst t = rows[0];\nconst id = $('Prepare Admin Command').item.json.view_ticket_id;\nif (!t?.id) {\n  return [{ json: { method: 'sendMessage', chat_id: $('Prepare Admin Command').item.json.chat_id, text: 'Тикет #' + id + ' не найден.' } }];\n}\nconst username = t.username ? '@' + t.username : String(t.telegram_user_id);\nconst date = new Date(t.created_at).toLocaleString('ru-RU');\nconst text = '🎫 Тикет #' + t.id + '\\nСтатус: ' + t.status + '\\nПользователь: ' + username + '\\nСоздан: ' + date + '\\n\\nВопрос:\\n' + t.question + '\\n\\nОтветить:\\n/reply ' + t.id + ' текст ответа';\nreturn [{ json: { method: 'sendMessage', chat_id: $('Prepare Admin Command').item.json.chat_id, text } }];"
      },
