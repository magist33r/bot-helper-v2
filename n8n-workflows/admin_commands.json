    {
      "parameters": {
        "jsCode": "const root = $input.first().json;\nconst headers = root.headers || {};\nconst secret = headers['x-telegram-bot-api-secret-token'] || headers['X-Telegram-Bot-Api-Secret-Token'];\nif (!secret || secret !== $env.TG_ADMIN_WEBHOOK_SECRET) {\n  throw new Error('Forbidden: invalid webhook secret');\n}\n\nconst update = root.body && typeof root.body === 'object' ? root.body : root;\nconst message = update.message || {};\nconst text = String(message.text || '').trim();\nconst command = text.split(/\\s+/)[0].toLowerCase();\nconst userId = message.from?.id ?? 0;\nconst chatId = message.chat?.id ?? 0;\nconst adminIds = String($env.ADMIN_TELEGRAM_IDS || '').split(',').map(id => id.trim()).filter(Boolean);\nconst isAdmin = adminIds.includes(String(userId));\n\nconst replyMatch = text.match(/^\\/reply(?:@\\w+)?\\s+#?(\\d+)\\s+([\\s\\S]+)/i);\nconst isReplyCommand = /^\\/reply(?:@\\w+)?(?:\\s|$)/i.test(text);\nconst ticketMatch = text.match(/^\\/ticket(?:@\\w+)?\\s+#?(\\d+)/i);\nconst isTicketCommand = /^\\/ticket(?:@\\w+)?(?:\\s|$)/i.test(text);\n\nlet directReply = '';\nif (!message.message_id) directReply = 'Нет сообщения.';\nelse if (!isAdmin) directReply = 'Нет доступа.';\nelse if (command === '/start' || command === '/help') directReply = [\n  'Админ-команды:',\n  '/stats — статистика бота',\n  '/feedback — оценки ответов за 7 дней',\n  '/tickets — открытые тикеты',\n  '/ticket 5 — посмотреть детали тикета #5',\n  '/reply 3 текст ответа — ответить пользователю и пометить тикет answered',\n  '/reload — загрузить KNOWLEDGE_SEED_TEXT в базу знаний'\n].join('\\n');\nelse if (isReplyCommand && !replyMatch) directReply = 'Формат ответа: /reply 3 текст ответа';\nelse if (isTicketCommand && !ticketMatch) directReply = 'Формат просмотра: /ticket 5';\nelse if (!['/stats', '/tickets', '/reload', '/feedback'].includes(command) && !isReplyCommand && !isTicketCommand) directReply = 'Неизвестная команда. Доступны: /stats, /feedback, /tickets, /ticket, /reply, /reload';\n\nreturn [{ json: {\n  chat_id: chatId,\n  user_id: userId,\n  text,\n  command,\n  direct_reply: directReply,\n  has_direct_reply: Boolean(directReply),\n  is_stats: isAdmin && command === '/stats',\n  is_feedback: isAdmin && command === '/feedback',\n  is_tickets: isAdmin && command === '/tickets',\n  is_ticket_view: isAdmin && Boolean(ticketMatch),\n  view_ticket_id: ticketMatch ? Number(ticketMatch[1]) : null,\n  is_reload: isAdmin && command === '/reload',\n  is_reply: isAdmin && Boolean(replyMatch),\n  reply_ticket_id: replyMatch ? Number(replyMatch[1]) : null,\n  reply_text: replyMatch ? replyMatch[2].trim() : ''\n} }];"
      },
