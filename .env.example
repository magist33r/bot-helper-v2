# n8n image. Empty = n8nio/n8n:latest from docker-compose default.
N8N_IMAGE=

# Public n8n UI address and webhook base. Example: N8N_HOST=n8n.swagadayz.ru, WEBHOOK_URL=https://bot.swagadayz.ru/.
N8N_HOST=
N8N_PORT=
N8N_PROTOCOL=
WEBHOOK_URL=

# Timezone settings. Example: Europe/Samara.
GENERIC_TIMEZONE=
TZ=

# Required by n8n to keep credentials decryptable after container restart.
N8N_ENCRYPTION_KEY=

# Required for production. true enables basic auth on n8n editor UI.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
# Generate: openssl rand -base64 32
N8N_BASIC_AUTH_PASSWORD=
N8N_BLOCK_ENV_ACCESS_IN_NODE=

# Allow n8n Code nodes to call Telegram via native Node.js https when Telegram POST is slow/blocked.
NODE_FUNCTION_ALLOW_BUILTIN=https,dns

# Run Code nodes in main n8n process; avoids Telegram outbound timeouts from internal task-runner on this VPS.
N8N_RUNNERS_ENABLED=false

# n8n execution logs auto-cleanup (recommended for production).
EXECUTIONS_DATA_PRUNE=true
# Max execution age in hours (168 = 7 days).
EXECUTIONS_DATA_MAX_AGE=168
# Maximum number of stored executions before pruning old records.
EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000

# OpenAI API key with access to text-embedding-3-small and gpt-4o-mini.
OPENAI_API_KEY=
# AITunnel OpenAI-compatible proxy base URL.
OPENAI_BASE_URL=https://aitunnel.ru/v1

# Supabase project URL and service role key. Use service role only inside trusted self-hosted n8n.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram bot token from BotFather. Add it to an n8n Telegram credential after import.
TELEGRAM_BOT_TOKEN=

# Separate Telegram bot token for admin commands (/stats, /tickets, /reload).
TELEGRAM_ADMIN_BOT_TOKEN=

# Secret for Telegram setWebhook (sent in X-Telegram-Bot-Api-Secret-Token).
# Generate: openssl rand -hex 32
TG_WEBHOOK_SECRET=
TG_ADMIN_WEBHOOK_SECRET=

# Shared secret for internal webhooks (/knowledge-ingestion and /close-ticket).
# Send in header X-Internal-Token.
INTERNAL_WEBHOOK_SECRET=

# Comma-separated Telegram numeric user IDs allowed to use admin commands.
ADMIN_TELEGRAM_IDS=

# Production webhook URL for Workflow #2, used by /reload admin command.
# Example: https://bot.swagadayz.ru/webhook/knowledge-ingestion
KNOWLEDGE_INGESTION_WEBHOOK_URL=

# Optional seed knowledge used by /reload. For large seeds, call the ingestion webhook directly instead.
KNOWLEDGE_SEED_TEXT=


