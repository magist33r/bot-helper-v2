# n8n image. Empty = n8nio/n8n:latest from docker-compose default.
N8N_IMAGE=

# Public n8n address. Example: N8N_HOST=n8n.example.com, N8N_PROTOCOL=https.
N8N_HOST=
N8N_PORT=
N8N_PROTOCOL=
WEBHOOK_URL=

# Timezone settings. Example: Europe/Samara.
GENERIC_TIMEZONE=
TZ=

# Required by n8n to keep credentials decryptable after container restart.
N8N_ENCRYPTION_KEY=

# Optional n8n basic auth for the editor UI. Example: true.
N8N_BASIC_AUTH_ACTIVE=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
N8N_BLOCK_ENV_ACCESS_IN_NODE=

# Allow n8n Code nodes to call Telegram via native Node.js https when Telegram POST is slow/blocked.
NODE_FUNCTION_ALLOW_BUILTIN=https,dns

# Run Code nodes in main n8n process; avoids Telegram outbound timeouts from internal task-runner on this VPS.
N8N_RUNNERS_ENABLED=false

# OpenAI API key with access to text-embedding-3-small and gpt-4o-mini.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Supabase project URL and service role key. Use service role only inside trusted self-hosted n8n.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram bot token from BotFather. Add it to an n8n Telegram credential after import.
TELEGRAM_BOT_TOKEN=

# Separate Telegram bot token for admin commands (/stats, /tickets, /reload).
TELEGRAM_ADMIN_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to use admin commands.
ADMIN_TELEGRAM_IDS=

# Production webhook URL for Workflow #2, used by /reload admin command.
# Example: https://n8n.example.com/webhook/knowledge-ingestion
KNOWLEDGE_INGESTION_WEBHOOK_URL=

# Optional seed knowledge used by /reload. For large seeds, call the ingestion webhook directly instead.
KNOWLEDGE_SEED_TEXT=


